generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  job_id           String    @id
  workflow_type    String
  workflow_version String    @default("1")
  actor_type       String
  actor_id         String
  source           String
  source_ref       String?
  parent_job_id    String?
  artifact_ref     String?
  status           String    @default("queued")
  current_step     String?
  started_at       DateTime?
  ended_at         DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  steps  JobStep[]
  events JobEvent[]

  @@index([actor_type, actor_id])
  @@index([parent_job_id])
  @@index([status])
  @@map("jobs")
}

model JobStep {
  id         Int       @id @default(autoincrement())
  job_id     String
  step_name  String
  status     String    @default("pending")
  attempt    Int       @default(1)
  started_at DateTime?
  ended_at   DateTime?
  error      String?
  created_at DateTime  @default(now())

  job Job @relation(fields: [job_id], references: [job_id], onDelete: Cascade)

  @@index([job_id, step_name])
  @@map("job_steps")
}

model JobEvent {
  id         Int      @id @default(autoincrement())
  job_id     String
  event_type String
  step_name  String?
  payload    Json?
  created_at DateTime @default(now())

  job Job @relation(fields: [job_id], references: [job_id], onDelete: Cascade)

  @@index([job_id])
  @@index([event_type])
  @@map("job_events")
}