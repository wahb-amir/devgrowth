# ─── Server ───────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ─── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/devgrowth
MONGODB_DB_NAME=devgrowth
GITHUB_TOKEN=

# ─── GitHub API ───────────────────────────────────────────
# Required: Personal Access Token with read:user, public_repo scopes
# Optional: GitHub OAuth App credentials (for user auth in Phase 6)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Pipeline ─────────────────────────────────────────────
PIPELINE_VERSION=0.1.0
SCORER_VERSION=0.1.0
INSIGHT_VERSION=0.1.0
# Max developers to ingest per cron tick
INGESTION_BATCH_SIZE=10
# How many GitHub API requests we can make per hour (5000 for authenticated)
GITHUB_RATE_LIMIT_PER_HOUR=5000

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
